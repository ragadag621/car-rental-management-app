@page "/cars/{Id:int}"
@inject ICarService CarService
@inject IBookingService BookingService
@inject IRentalService RentalService
@inject UserSession Session
@inject NavigationManager Nav
@rendermode InteractiveServer

<PageTitle>@(_car?.Name ?? "Car") - DriveNow</PageTitle>

@if (_car is null)
{
    <div class="rounded-2xl border border-neutral-800 bg-neutral-900 p-10 text-center">
        <p class="text-neutral-300">Sorry, this car could not be found.</p>
        <a href="/" class="mt-4 inline-block font-semibold text-amber-400 hover:underline">Back to all cars</a>
    </div>
}
else
{
    <a href="/" class="mb-6 inline-flex items-center gap-1 text-sm font-medium text-neutral-400 transition hover:text-amber-400">
        &larr; Back to all cars
    </a>

    <div class="grid gap-8 lg:grid-cols-2">
        <!-- Image + description -->
        <div>
            <div class="overflow-hidden rounded-2xl border border-neutral-800 bg-neutral-800">
                <img src="@_car.ImageUrl" alt="@_car.Name" class="aspect-video w-full object-cover" />
            </div>

            <div class="mt-4 flex items-center gap-3">
                <span class="rounded-full px-3 py-1 text-xs font-semibold text-neutral-950" style="background-color:@_car.AccentColor;">
                    @_car.Category
                </span>
                <span class="text-sm text-neutral-400">@_car.Brand &middot; @_car.Year</span>
            </div>

            <h1 class="mt-3 text-3xl font-extrabold text-neutral-50">@_car.Name</h1>
            <p class="mt-3 leading-relaxed text-neutral-400">@_car.Description</p>

            <!-- Specs -->
            <div class="mt-6 grid grid-cols-2 gap-4 sm:grid-cols-3">
                <SpecItem Label="Top speed" Value="@($"{_car.TopSpeedKmh} km/h")" />
                <SpecItem Label="Horsepower" Value="@($"{_car.Horsepower} hp")" />
                <SpecItem Label="Seats" Value="@_car.Seats.ToString()" />
                <SpecItem Label="Transmission" Value="@_car.Transmission" />
                <SpecItem Label="Fuel" Value="@_car.FuelType" />
                <SpecItem Label="Daily rate" Value="@_car.DailyPrice.ToString("C0")" />
            </div>
        </div>

        <!-- Booking panel -->
        <div>
            <div class="sticky top-24 rounded-2xl border border-neutral-800 bg-neutral-900 p-6">
                <div class="flex items-baseline justify-between">
                    <h2 class="text-xl font-bold text-neutral-50">Book this car</h2>
                    <div class="text-right">
                        <span class="text-2xl font-extrabold text-amber-400">@_car.DailyPrice.ToString("C0")</span>
                        <span class="text-sm text-neutral-500">/ day</span>
                    </div>
                </div>

                @if (!Session.IsLoggedIn)
                {
                    <div class="mt-6 rounded-xl border border-neutral-800 bg-neutral-950 p-5 text-center">
                        <p class="text-neutral-300">Please sign in to book a car.</p>
                        <a href="/login" class="mt-3 inline-block rounded-lg bg-amber-500 px-4 py-2 text-sm font-semibold text-neutral-950 transition hover:bg-amber-400">
                            Sign in
                        </a>
                    </div>
                }
                else if (_summary is null)
                {
                    <EditForm Model="_booking" OnValidSubmit="SubmitBooking" class="mt-6 space-y-4">
                        <DataAnnotationsValidator />

                        <div>
                            <label class="mb-1 block text-sm font-medium text-neutral-300">Your name</label>
                            <InputText @bind-Value="_booking.CustomerName"
                                       class="w-full rounded-lg border border-neutral-700 bg-neutral-950 px-3 py-2 text-neutral-100 outline-none focus:border-amber-500" />
                            <ValidationMessage For="() => _booking.CustomerName" class="mt-1 text-xs text-red-400" />
                        </div>

                        <div class="grid grid-cols-2 gap-3">
                            <div>
                                <label class="mb-1 block text-sm font-medium text-neutral-300">Start date</label>
                                <InputDate @bind-Value="_booking.StartDate"
                                           class="w-full rounded-lg border border-neutral-700 bg-neutral-950 px-3 py-2 text-neutral-100 outline-none focus:border-amber-500" />
                                <ValidationMessage For="() => _booking.StartDate" class="mt-1 text-xs text-red-400" />
                            </div>
                            <div>
                                <label class="mb-1 block text-sm font-medium text-neutral-300">End date</label>
                                <InputDate @bind-Value="_booking.EndDate"
                                           class="w-full rounded-lg border border-neutral-700 bg-neutral-950 px-3 py-2 text-neutral-100 outline-none focus:border-amber-500" />
                                <ValidationMessage For="() => _booking.EndDate" class="mt-1 text-xs text-red-400" />
                            </div>
                        </div>

                        @if (_errorMessage is not null)
                        {
                            <p class="rounded-lg bg-red-500/10 px-3 py-2 text-sm text-red-400">@_errorMessage</p>
                        }

                        <button type="submit"
                                class="w-full rounded-lg bg-amber-500 py-2.5 font-semibold text-neutral-950 transition hover:bg-amber-400">
                            Calculate &amp; confirm
                        </button>
                    </EditForm>
                }
                else
                {
                    <div class="mt-6 space-y-3">
                        <div class="rounded-lg bg-emerald-500/10 px-3 py-2 text-sm font-medium text-emerald-400">
                            Booking confirmed! You can view it under My Rentals.
                        </div>

                        <dl class="divide-y divide-neutral-800 rounded-lg border border-neutral-800">
                            <SummaryRow Label="Customer" Value="@_summary.CustomerName" />
                            <SummaryRow Label="From" Value="@_summary.StartDate.ToString("MMM d, yyyy")" />
                            <SummaryRow Label="To" Value="@_summary.EndDate.ToString("MMM d, yyyy")" />
                            <SummaryRow Label="Days" Value="@_summary.NumberOfDays.ToString()" />
                            <SummaryRow Label="Daily rate" Value="@_summary.Car.DailyPrice.ToString("C0")" />
                        </dl>

                        <div class="flex items-center justify-between rounded-lg bg-amber-500/10 px-4 py-3">
                            <span class="font-semibold text-neutral-200">Total</span>
                            <span class="text-2xl font-extrabold text-amber-400">@_summary.TotalPrice.ToString("C2")</span>
                        </div>

                        <div class="flex gap-3">
                            <a href="/my-rentals" class="flex-1 rounded-lg bg-amber-500 py-2.5 text-center font-semibold text-neutral-950 transition hover:bg-amber-400">
                                View my rentals
                            </a>
                            <button @onclick="ResetBooking" class="flex-1 rounded-lg border border-neutral-700 py-2.5 font-semibold text-neutral-200 transition hover:bg-neutral-800">
                                Book again
                            </button>
                        </div>
                    </div>
                }
            </div>
        </div>
    </div>
}

@code {
    [Parameter] public int Id { get; set; }

    private Car? _car;
    private Booking _booking = new();
    private BookingSummary? _summary;
    private string? _errorMessage;

    protected override void OnParametersSet()
    {
        _car = CarService.GetCarById(Id);
        _booking = new Booking
        {
            StartDate = DateTime.Today,
            EndDate = DateTime.Today.AddDays(1),
            CustomerName = Session.CurrentUser?.FullName ?? string.Empty
        };
    }

    private void SubmitBooking()
    {
        if (_car is null) return;

        var result = BookingService.CreateBooking(_car, _booking);

        if (!result.Success)
        {
            _errorMessage = result.ErrorMessage;
            return;
        }

        _errorMessage = null;
        _summary = result.Summary;

        // Persist the rental for the signed-in user.
        if (Session.CurrentUser is not null && _summary is not null)
        {
            RentalService.AddRental(Session.CurrentUser.Id, _summary);
        }
    }

    private void ResetBooking()
    {
        _summary = null;
        _errorMessage = null;
        _booking = new Booking
        {
            StartDate = DateTime.Today,
            EndDate = DateTime.Today.AddDays(1),
            CustomerName = Session.CurrentUser?.FullName ?? string.Empty
        };
    }
}
