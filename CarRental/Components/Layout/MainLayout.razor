@inherits LayoutComponentBase

@* App shell: a sticky header with branding plus the routed page content. *@
<div class="min-h-screen bg-neutral-950">
    <header class="sticky top-0 z-20 border-b border-neutral-800 bg-neutral-950/80 backdrop-blur">
        <div class="mx-auto flex max-w-6xl items-center justify-between px-4 py-4">
            <div class="flex items-center gap-2">
                <span class="flex h-8 w-8 items-center justify-center rounded-lg bg-amber-500 font-extrabold text-neutral-950">D</span>
                <span class="text-lg font-bold tracking-tight text-neutral-50">DriveNow</span>
            </div>
            <span class="text-sm font-medium text-neutral-400">Premium Car Rental</span>
        </div>
    </header>

    <main class="mx-auto max-w-6xl px-4 py-8">
        @Body
    </main>

    <footer class="border-t border-neutral-800 py-6 text-center text-sm text-neutral-500">
        Built with ASP.NET Core Blazor &amp; Tailwind CSS
    </footer>
</div>
