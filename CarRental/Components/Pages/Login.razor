@page "/login"
@inject IAuthService Auth
@inject UserSession Session
@inject NavigationManager Nav
@rendermode InteractiveServer

<PageTitle>Sign in - DriveNow</PageTitle>

<div class="mx-auto max-w-md">
    <div class="rounded-2xl border border-neutral-800 bg-neutral-900 p-8">
        <h1 class="text-2xl font-bold text-neutral-50">Welcome back</h1>
        <p class="mt-1 text-sm text-neutral-400">Sign in to manage your rentals.</p>

        @if (_error is not null)
        {
            <div class="mt-4 rounded-lg border border-red-500/40 bg-red-500/10 px-4 py-2 text-sm text-red-300">
                @_error
            </div>
        }

        <EditForm Model="_model" OnValidSubmit="HandleLogin" class="mt-6 space-y-4">
            <DataAnnotationsValidator />

            <div>
                <label class="mb-1 block text-sm font-medium text-neutral-300">Email</label>
                <InputText @bind-Value="_model.Email" type="email"
                           class="w-full rounded-lg border border-neutral-700 bg-neutral-800 px-3 py-2 text-neutral-100 outline-none focus:border-amber-500" />
                <ValidationMessage For="() => _model.Email" class="mt-1 text-xs text-red-400" />
            </div>

            <div>
                <label class="mb-1 block text-sm font-medium text-neutral-300">Password</label>
                <InputText @bind-Value="_model.Password" type="password"
                           class="w-full rounded-lg border border-neutral-700 bg-neutral-800 px-3 py-2 text-neutral-100 outline-none focus:border-amber-500" />
                <ValidationMessage For="() => _model.Password" class="mt-1 text-xs text-red-400" />
            </div>

            <button type="submit"
                    class="w-full rounded-lg bg-amber-500 py-2.5 font-semibold text-neutral-950 transition hover:bg-amber-400">
                Sign in
            </button>
        </EditForm>

        <p class="mt-6 text-center text-sm text-neutral-400">
            Don't have an account?
            <a href="/register" class="font-semibold text-amber-400 hover:underline">Register</a>
        </p>
    </div>
</div>

@code {
    private readonly LoginModel _model = new();
    private string? _error;

    private void HandleLogin()
    {
        _error = null;
        var result = Auth.Login(_model);

        if (!result.Success)
        {
            _error = result.ErrorMessage;
            return;
        }

        Session.SignIn(result.User!);
        Nav.NavigateTo("/");
    }
}
