@page "/contact"
@rendermode InteractiveServer

<PageTitle>Contact & Location - DriveNow</PageTitle>

<h1 class="mb-2 text-3xl font-extrabold text-neutral-50">Contact &amp; Location</h1>
<p class="mb-8 max-w-2xl text-neutral-400">
    Have a question or need help with a booking? Reach out and our team will get back to you.
</p>

<div class="grid gap-8 lg:grid-cols-2">
    <!-- Company info -->
    <div class="space-y-4">
        <div class="rounded-2xl border border-neutral-800 bg-neutral-900 p-6">
            <h2 class="text-lg font-bold text-neutral-50">Where we are</h2>
            <p class="mt-2 text-neutral-400">
                DriveNow Head Office<br />
                123 King Fahd Road<br />
                Riyadh, Saudi Arabia
            </p>
        </div>

        <div class="rounded-2xl border border-neutral-800 bg-neutral-900 p-6">
            <h2 class="text-lg font-bold text-neutral-50">Get in touch</h2>
            <ul class="mt-2 space-y-1 text-neutral-400">
                <li>Phone: +966 11 234 5678</li>
                <li>Email: support@drivenow.example</li>
                <li>Hours: Sat&ndash;Thu, 8:00 AM &ndash; 10:00 PM</li>
            </ul>
        </div>
    </div>

    <!-- Contact form -->
    <div class="rounded-2xl border border-neutral-800 bg-neutral-900 p-6">
        <h2 class="text-lg font-bold text-neutral-50">Send us a message</h2>

        @if (_sent)
        {
            <div class="mt-4 rounded-lg border border-emerald-500/40 bg-emerald-500/10 px-4 py-3 text-sm text-emerald-300">
                Thanks, @_name! Your message has been received. We'll reply soon.
            </div>
        }

        <EditForm Model="_form" OnValidSubmit="Submit" class="mt-4 space-y-4">
            <DataAnnotationsValidator />

            <div>
                <label class="mb-1 block text-sm font-medium text-neutral-300">Name</label>
                <InputText @bind-Value="_form.Name"
                           class="w-full rounded-lg border border-neutral-700 bg-neutral-950 px-3 py-2 text-neutral-100 outline-none focus:border-amber-500" />
                <ValidationMessage For="() => _form.Name" class="mt-1 text-xs text-red-400" />
            </div>

            <div>
                <label class="mb-1 block text-sm font-medium text-neutral-300">Email</label>
                <InputText @bind-Value="_form.Email" type="email"
                           class="w-full rounded-lg border border-neutral-700 bg-neutral-950 px-3 py-2 text-neutral-100 outline-none focus:border-amber-500" />
                <ValidationMessage For="() => _form.Email" class="mt-1 text-xs text-red-400" />
            </div>

            <div>
                <label class="mb-1 block text-sm font-medium text-neutral-300">Message</label>
                <InputTextArea @bind-Value="_form.Message" rows="4"
                               class="w-full rounded-lg border border-neutral-700 bg-neutral-950 px-3 py-2 text-neutral-100 outline-none focus:border-amber-500" />
                <ValidationMessage For="() => _form.Message" class="mt-1 text-xs text-red-400" />
            </div>

            <button type="submit"
                    class="w-full rounded-lg bg-amber-500 py-2.5 font-semibold text-neutral-950 transition hover:bg-amber-400">
                Send message
            </button>
        </EditForm>
    </div>
</div>

@code {
    private readonly ContactForm _form = new();
    private bool _sent;
    private string _name = string.Empty;

    private void Submit()
    {
        _name = _form.Name;
        _sent = true;
        _form.Name = string.Empty;
        _form.Email = string.Empty;
        _form.Message = string.Empty;
    }

    public class ContactForm
    {
        [System.ComponentModel.DataAnnotations.Required(ErrorMessage = "Please enter your name.")]
        public string Name { get; set; } = string.Empty;

        [System.ComponentModel.DataAnnotations.Required(ErrorMessage = "Email is required.")]
        [System.ComponentModel.DataAnnotations.EmailAddress(ErrorMessage = "Enter a valid email.")]
        public string Email { get; set; } = string.Empty;

        [System.ComponentModel.DataAnnotations.Required(ErrorMessage = "Please enter a message.")]
        public string Message { get; set; } = string.Empty;
    }
}
