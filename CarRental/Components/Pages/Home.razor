@page "/"
@inject ICarService CarService
@rendermode InteractiveServer

<PageTitle>DriveNow - Premium Car Rental</PageTitle>

<!-- Hero -->
<section class="mb-10">
    <h1 class="text-balance text-4xl font-extrabold tracking-tight text-neutral-50 sm:text-5xl">
        Rent the perfect car for every journey
    </h1>
    <p class="mt-4 max-w-2xl text-pretty text-lg leading-relaxed text-neutral-400">
        Browse our fleet, filter by category, and book in seconds. Transparent daily pricing, no hidden fees.
    </p>
</section>

<!-- Category filters -->
<div class="mb-8 flex flex-wrap gap-3">
    <button @onclick="() => FilterBy(null)" class="@FilterButtonClass(null)">All</button>
    @foreach (var category in _categories)
    {
        <button @onclick="() => FilterBy(category)" class="@FilterButtonClass(category)">@category</button>
    }
</div>

<!-- Car grid -->
@if (_cars.Count == 0)
{
    <p class="text-neutral-400">No cars available in this category.</p>
}
else
{
    <div class="grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-3">
        @foreach (var car in _cars)
        {
            <CarCard Car="car" />
        }
    </div>
}

@code {
    private IReadOnlyList<CarCategory> _categories = Array.Empty<CarCategory>();
    private IReadOnlyList<Car> _cars = Array.Empty<Car>();
    private CarCategory? _activeCategory;

    protected override void OnInitialized()
    {
        _categories = CarService.GetAvailableCategories();
        _cars = CarService.GetAllCars();
    }

    private void FilterBy(CarCategory? category)
    {
        _activeCategory = category;
        _cars = CarService.GetCarsByCategory(category);
    }

    private string FilterButtonClass(CarCategory? category)
    {
        var isActive = _activeCategory == category;
        var baseClasses = "rounded-full px-5 py-2 text-sm font-semibold transition ";
        return isActive
            ? baseClasses + "bg-amber-500 text-neutral-950"
            : baseClasses + "border border-neutral-700 text-neutral-300 hover:bg-neutral-800";
    }
}
