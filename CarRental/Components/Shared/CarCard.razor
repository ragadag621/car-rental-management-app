@* A single car in the catalog grid. The whole card links to the detail page. *@

<a href="@($"/cars/{Car.Id}")"
   class="group flex flex-col overflow-hidden rounded-2xl border border-neutral-800 bg-neutral-900 transition hover:border-amber-500/60 hover:shadow-lg hover:shadow-amber-500/5">

    <div class="relative aspect-video overflow-hidden bg-neutral-800">
        <img src="@Car.ImageUrl" alt="@Car.Name"
             class="h-full w-full object-cover transition duration-300 group-hover:scale-105" />
        <span class="absolute left-3 top-3 rounded-full px-2.5 py-1 text-xs font-semibold text-neutral-950"
              style="background-color:@Car.AccentColor;">
            @Car.Category
        </span>
    </div>

    <div class="flex flex-1 flex-col p-5">
        <div class="flex items-start justify-between gap-2">
            <div>
                <h3 class="font-bold text-neutral-50">@Car.Name</h3>
                <p class="text-sm text-neutral-400">@Car.Brand &middot; @Car.Year</p>
            </div>
            <div class="text-right">
                <p class="text-lg font-extrabold text-amber-400">@Car.DailyPrice.ToString("C0")</p>
                <p class="text-xs text-neutral-500">per day</p>
            </div>
        </div>

        <div class="mt-4 flex items-center gap-4 text-xs text-neutral-400">
            <span>@Car.Seats seats</span>
            <span>@Car.TopSpeedKmh km/h</span>
            <span>@Car.Transmission</span>
        </div>

        <span class="mt-5 inline-flex w-full items-center justify-center rounded-lg bg-neutral-800 py-2 text-sm font-semibold text-neutral-100 transition group-hover:bg-amber-500 group-hover:text-neutral-950">
            View details
        </span>
    </div>
</a>

@code {
    [Parameter, EditorRequired] public Car Car { get; set; } = default!;
}
